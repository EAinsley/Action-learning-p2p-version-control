<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<?import javafx.geometry.Insets?>
<VBox alignment="CENTER" spacing="20.0" xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.codehaus.mojo.frontendtest.RepositoryListController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
    </padding>
    <Label text="Select Repository" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

    <ListView fx:id="repoListView" onMouseClicked="#handleRepoClick" VBox.vgrow="ALWAYS" />
    <VBox>
        <Button maxWidth="Infinity">Add new Repo</Button>
        <Button maxWidth="Infinity">Share Repo</Button>
        <Button maxWidth="Infinity">Join new Repo</Button>
        <Button maxWidth="Infinity">Delete/Untrack repo</Button>
    </VBox>
</VBox>

