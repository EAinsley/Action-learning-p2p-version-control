<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>


<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.codehaus.mojo.frontendtest.RepoStatusController"
            prefWidth="380" prefHeight="340"
            style="-fx-background-color: white; -fx-border-color: black; -fx-border-width: 3;">

    <!-- Title bar -->
    <top>
        <Label fx:id="repoNameLabel" text="Repository name" maxWidth="Infinity"
               style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: black;
                      -fx-border-color: black; -fx-border-width: 0 0 3 0;
                      -fx-padding: 8 10 8 10;"/>
    </top>


    <center>
        <GridPane>
            <columnConstraints>
                <ColumnConstraints percentWidth="50"/>
                <ColumnConstraints percentWidth="50"/>
            </columnConstraints>
            <rowConstraints>
                <RowConstraints vgrow="ALWAYS"/>
            </rowConstraints>

            <!-- Left panel -->
            <VBox GridPane.columnIndex="0" GridPane.rowIndex="0"
                  style="-fx-border-color: black; -fx-border-width: 0 3 0 0;">
                <Label text="Files in repository." wrapText="true"
                       style="-fx-font-size: 13px; -fx-padding: 8 8 8 8;"/>
                <ListView fx:id="filesListView" VBox.vgrow="ALWAYS"
                          style="-fx-border-width: 0;"/>
            </VBox>

            <!-- Right panel -->
            <VBox GridPane.columnIndex="1" GridPane.rowIndex="0">
                <Label text="List of changes" wrapText="true"
                       style="-fx-font-size: 13px; -fx-padding: 8 8 8 8;"/>
                <TextArea fx:id="changesTextArea" editable="false" wrapText="true"
                          VBox.vgrow="ALWAYS"
                          style="-fx-font-family: 'Consolas', 'Monospaced'; -fx-border-width: 0;"/>
            </VBox>
        </GridPane>
    </center>

    <!-- Bottom status bar -->
    <bottom>
        <HBox alignment="CENTER_LEFT"
              style="-fx-border-color: black; -fx-border-width: 3 0 0 0;">
            <Label fx:id="syncStatusLabel" text="sync status:"
                   style="-fx-padding: 6 10 6 10; -fx-border-color: black; -fx-border-width: 0 3 0 0;"  HBox.hgrow="ALWAYS"  maxWidth="Infinity"/>
            <Label fx:id="peersLabel" text="peers : (number)"
                   style="-fx-padding: 6 10 6 10; -fx-border-color: black; -fx-border-width: 0 3 0 0;"   HBox.hgrow="ALWAYS"  maxWidth="Infinity"/>
            <Label fx:id="onlineStatusLabel" text="Online/offline"
                   style="-fx-padding: 6 10 6 10;"  HBox.hgrow="ALWAYS"  maxWidth="Infinity"/>
        </HBox>
    </bottom>

</BorderPane>
